DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mecanice
## LLM (chat/completions)
# Preferred names (use these to override legacy vars)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# Legacy / OpenAI aliases (optional)
# If set, they will be used as fallbacks when LLM_* are not present
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-5-mini

## Embeddings
EMBEDDINGS_PROVIDER=openai_compatible
