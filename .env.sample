DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mecanice
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
## LLM (chat/completions)
# Preferred names (use these to override legacy vars)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# Legacy / OpenAI aliases (optional)
# If set, they will be used as fallbacks when LLM_* are not present
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-5-mini

## Embeddings
EMBEDDINGS_PROVIDER=openai_compatible
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
ADMIN_TOKEN=change-me
EMBEDDINGS_PROVIDER=dummy

WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Consulta de placa (dados mínimos do veículo para fluxo de cotação)
PLATE_LOOKUP_BASE_URL=https://brasilapi.com.br/api/placa/v1
